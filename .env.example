NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/secureasset
CLIENT_URL=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
JWT_ISSUER=secureasset-api
JWT_AUDIENCE=secureasset-web
DEMO_OTP=123456

# Legacy uploads are disabled by default. Document Vault files use protected routes.
UPLOAD_DIR=server/src/uploads
MAX_FILE_MB=10
LEGACY_PUBLIC_UPLOADS=false
PAYMENT_AUTO_APPROVE=false

# Universal Document Vault
STORAGE_DRIVER=local
VAULT_STORAGE_DIR=storage/vault
VAULT_ENCRYPTION_KEY=replace-with-a-long-random-storage-encryption-secret
VAULT_TEMP_DIR=storage/tmp
VAULT_MAX_FILE_MB=250
VAULT_CHUNK_MB=12
TRASH_RETENTION_DAYS=60
VAULT_PURGE_CRON=17 2 * * *
VAULT_ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.txt,.rtf,.odt,.xls,.xlsx,.csv,.ppt,.pptx,.jpg,.jpeg,.png,.webp,.gif,.svg,.tiff,.heic,.mp4,.mov,.avi,.mkv,.webm,.mp3,.wav,.m4a,.aac,.dxf,.dwg,.kml,.kmz,.geojson,.zip,.rar,.7z

# Optional ClamAV server-side malware scan
CLAMAV_ENABLED=false
CLAMAV_COMMAND=clamdscan

# Optional S3-compatible production storage. Set STORAGE_DRIVER=s3 to enable.
S3_REGION=ap-south-1
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
S3_FORCE_PATH_STYLE=false
S3_SSE=AES256
S3_KMS_KEY_ID=

SURVEY_PLATFORM_COMMISSION_PERCENT=5
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=SecureAsset <no-reply@example.com>

VITE_API_URL=/api/v1

# Dynamic CMS and rental automation
CMS_ASSET_DIR=storage/site-assets
RENT_AUTOMATION_CRON=7 1 * * *

VITE_ENABLE_DEMO_ACCOUNTS=false

# Automatic database migrations (enabled by default)
AUTO_DB_MIGRATIONS=true
# Optional distributed-lock tuning in milliseconds
AUTO_DB_MIGRATION_LOCK_TTL_MS=1200000
AUTO_DB_MIGRATION_WAIT_MS=1800000
AUTO_DB_MIGRATION_POLL_MS=3000

# Never seed synthetic tenants, KYC records or property spaces in production unless explicitly requested.
SEED_DEMO_RENTAL_DATA=false
