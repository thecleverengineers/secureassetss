NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/secureasset
CLIENT_URL=https://secureasset.in
PUBLIC_APP_URL=https://secureasset.in
JWT_ACCESS_SECRET=GENERATE_A_NEW_RANDOM_SECRET_OF_AT_LEAST_64_CHARACTERS
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_RANDOM_SECRET_OF_AT_LEAST_64_CHARACTERS
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
JWT_ISSUER=secureasset-api
JWT_AUDIENCE=secureasset-web
LEGACY_PUBLIC_UPLOADS=false
PAYMENT_AUTO_APPROVE=false

# local = encrypted persistent VPS storage; s3 = AWS/S3-compatible storage.
STORAGE_DRIVER=local
VAULT_STORAGE_DIR=/var/lib/secureasset/vault
VAULT_ENCRYPTION_KEY=GENERATE_A_SEPARATE_RANDOM_KEY_OF_AT_LEAST_64_CHARACTERS
VAULT_TEMP_DIR=/var/lib/secureasset/tmp
VAULT_MAX_FILE_MB=250
VAULT_CHUNK_MB=12
TRASH_RETENTION_DAYS=60
VAULT_PURGE_CRON=17 2 * * *
VAULT_ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.txt,.rtf,.odt,.xls,.xlsx,.csv,.ppt,.pptx,.jpg,.jpeg,.png,.webp,.gif,.svg,.tiff,.heic,.mp4,.mov,.avi,.mkv,.webm,.mp3,.wav,.m4a,.aac,.dxf,.dwg,.kml,.kmz,.geojson,.zip,.rar,.7z

# Enable only after clamdscan and clamav-daemon are installed and healthy.
CLAMAV_ENABLED=false
CLAMAV_COMMAND=clamdscan

# Required only when STORAGE_DRIVER=s3. Static credentials may stay empty when an IAM role/default AWS credential provider is configured.
S3_REGION=ap-south-1
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
S3_FORCE_PATH_STYLE=false
S3_SSE=AES256
S3_KMS_KEY_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SecureAsset <no-reply@secureasset.in>
VITE_API_URL=/api/v1

CMS_ASSET_DIR=/var/lib/secureasset/site-assets
RENT_AUTOMATION_CRON=7 1 * * *
NOTIFICATION_DELIVERY_CRON=* * * * *
NOTIFICATION_BATCH_SIZE=200
PM2_MAX_MEMORY=1G

SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_TOKEN=
PUSH_WEBHOOK_URL=
PUSH_WEBHOOK_TOKEN=

SURVEY_PLATFORM_COMMISSION_PERCENT=5

AUTO_DB_MIGRATIONS=true
AUTO_DB_MIGRATION_LOCK_TTL_MS=1200000
AUTO_DB_MIGRATION_WAIT_MS=1800000
AUTO_DB_MIGRATION_POLL_MS=3000

# Never seed synthetic tenants, KYC records or property spaces in production unless explicitly requested.
SEED_DEMO_RENTAL_DATA=false
