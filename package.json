{
  "name": "secureasset-enterprise-production",
  "private": true,
  "version": "6.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n API,WEB -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/src/server.js",
    "build": "node scripts/build-production.js",
    "start": "node scripts/start-after-migrations.js server/src/server.js",
    "seed": "node server/src/seeds/seed.js",
    "seed:admin": "node server/src/seeds/ensureAdmin.js",
    "check": "npm run schema:check && npm run route:check && npm run build && node scripts/check-server-syntax.js",
    "setup:local": "node scripts/setup-local.js",
    "db:check": "node scripts/check-mongodb.js",
    "migrate:auth-identifiers": "node scripts/migrate-auth-identifiers.js",
    "auth:db-check": "node scripts/verify-auth-database.js",
    "migrate:tenant-landlord": "node scripts/migrate-tenant-landlord.js",
    "migrate:surveyor-subscription": "node scripts/migrate-surveyor-subscription.js",
    "start:production": "cross-env NODE_ENV=production node scripts/start-after-migrations.js server/src/server.js",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "npm run build && npm run pm2:reconcile && pm2 startOrReload ecosystem.config.cjs --env production --update-env && npm run pm2:verify",
    "pm2:restart": "npm run pm2:reconcile && pm2 startOrReload ecosystem.config.cjs --env production --update-env && npm run pm2:verify",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs secureasset --lines 200",
    "pm2:save": "pm2 save",
    "migrate:document-vault": "node scripts/migrate-document-vault.js",
    "vault:purge": "node scripts/purge-drive-trash.js",
    "pm2:status": "pm2 status",
    "db:indexes": "node scripts/create-production-indexes.js",
    "migrate:advanced-rental": "node scripts/migrate-advanced-rental.js",
    "rent:automation": "node scripts/process-rental-automation.js",
    "runtime:check": "node scripts/check-runtime.js",
    "deploy:production": "bash ./deploy.sh",
    "deploy:validate": "node scripts/validate-production-env.js",
    "preinstall": "node scripts/check-runtime.js",
    "db:repair-indexes": "node scripts/repair-production-indexes.js",
    "services:check": "node scripts/check-production-services.js",
    "schema:check": "node scripts/validate-schema-contracts.js",
    "lint:server": "eslint server scripts ecosystem.config.cjs --max-warnings=0",
    "test": "node --test test/*.test.js",
    "verify": "npm run runtime:check && npm run schema:check && npm run migration:check && npm run feature:check && npm run route:check && npm run audit:enterprise && npm run lint:server && npm run test && npm run build && ./node_modules/.bin/tsc --noEmit && node scripts/check-server-syntax.js",
    "feature:check": "node scripts/verify-feature-contracts.js",
    "certify:production": "npm run runtime:check && npm run deploy:validate && npm run db:check && npm run services:check && npm run db:repair-indexes && npm run db:indexes && npm run verify && npm audit --omit=dev --audit-level=high",
    "migrate:enterprise": "node scripts/migrate-enterprise-platform.js",
    "audit:enterprise": "node scripts/audit-enterprise-features.js",
    "notifications:process": "node scripts/process-notification-deliveries.js",
    "migrate:legacy-uploads": "node scripts/migrate-legacy-uploads.js",
    "verify:offline": "npm run runtime:check && npm run schema:check && npm run migration:check && npm run feature:check && npm run route:check && npm run audit:enterprise && npm run lint:server && npm run test && ./node_modules/.bin/tsc --noEmit && npm run build && node scripts/check-server-syntax.js && npm audit --omit=dev --audit-level=high",
    "route:check": "node scripts/validate-route-contracts.js",
    "db:auto-migrate": "node scripts/run-automatic-migrations.js",
    "db:auto-migrate:force": "node scripts/run-automatic-migrations.js --force",
    "auth:route-check": "node scripts/verify-auth-routing.js",
    "auth:repair": "bash scripts/repair-auth-routing.sh",
    "db:repair-surveyor-index": "node scripts/repair-surveyor-subscription-index.js",
    "db:repair-user-phone-index": "node scripts/repair-user-phone-index.js",
    "assets:route-check": "node scripts/verify-public-assets.js",
    "migration:check": "node scripts/validate-migration-contracts.js",
    "db:repair-legacy-objectids": "node scripts/repair-legacy-objectid-placeholders.js",
    "pm2:reconcile": "node scripts/reconcile-pm2-release.js --prepare",
    "pm2:verify": "node scripts/reconcile-pm2-release.js --verify",
    "nginx:repair": "bash scripts/repair-auth-routing.sh --nginx-only"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.821.0",
