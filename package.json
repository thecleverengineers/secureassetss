    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "country-state-city": "3.2.1",
    "cross-env": "^7.0.3",
    "date-fns": "3.6.0",
    "dotenv": "^16.6.1",
    "embla-carousel-react": "8.6.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "file-saver": "^2.0.5",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "input-otp": "1.4.2",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "0.487.0",
    "mongoose": "^8.16.4",
    "morgan": "^1.10.0",
    "motion": "12.23.24",
    "multer": "^2.0.2",
    "next-themes": "0.4.6",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.16.0",
    "pm2": "7.0.1",
    "react": "18.3.1",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    "react-router": "^7.18.0",
    "react-slick": "0.31.0",
    "recharts": "2.15.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@tailwindcss/vite": "4.1.12",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^9.2.0",
    "eslint": "9.39.2",
    "globals": "16.5.0",
    "nodemon": "^3.1.10",
    "tailwindcss": "4.1.12",
    "typescript": "^5.8.3",
    "vite": "6.3.5"
  },
  "overrides": {
    "exceljs": {
      "uuid": "11.1.1"
    },
    "ws": "8.21.0",
    "js-yaml": "5.1.0"
  },
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.16.0 <12"
  },
  "allowScripts": {
    "@tailwindcss/oxide@4.1.12": true,
    "esbuild@0.25.12": true
  }
}
